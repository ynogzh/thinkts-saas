{
  "title": "内容文章",
  "model": "content_article",
  "list": {
    "columns": [
      {
        "field": "title",
        "title": "Title",
        "width": 200
      },
      {
        "field": "tenant_id",
        "title": "Tenant id",
        "width": 80
      },
      {
        "field": "module_code",
        "title": "Module code",
        "width": 160
      },
      {
        "field": "category_id",
        "title": "Category id",
        "width": 80
      },
      {
        "field": "status",
        "title": "Status",
        "width": 160
      },
      {
        "field": "created_by",
        "title": "Created by",
        "width": 80
      },
      {
        "field": "content",
        "title": "Content",
        "width": 160
      },
      {
        "field": "id",
        "title": "Id",
        "width": 80
      }
    ],
    "orderBy": {
      "field": "id",
      "direction": "desc"
    },
    "pageSize": 20,
    "rowActions": [
      {
        "type": "view",
        "title": "查看"
      },
      {
        "type": "edit",
        "title": "编辑"
      },
      {
        "type": "delete",
        "title": "删除",
        "confirm": "确认删除？"
      }
    ],
    "headerActions": [
      {
        "type": "create",
        "title": "新增Content article",
        "icon": "plus"
      }
    ]
  },
  "search": {
    "fields": [
      {
        "field": "title",
        "title": "Title",
        "type": "input"
      },
      {
        "field": "tenant_id",
        "title": "Tenant id",
        "type": "numberRange"
      },
      {
        "field": "module_code",
        "title": "Module code",
        "type": "input"
      },
      {
        "field": "category_id",
        "title": "Category id",
        "type": "numberRange"
      }
    ],
    "showCount": 3
  },
  "form": {
    "groups": [
      {
        "title": "基本信息",
        "columns": 2,
        "fields": [
          {
            "field": "tenant_id",
            "title": "Tenant id",
            "type": "number",
            "required": true
          },
          {
            "field": "module_code",
            "title": "Module code",
            "type": "input"
          },
          {
            "field": "category_id",
            "title": "Category id",
            "type": "number"
          },
          {
            "field": "title",
            "title": "Title",
            "type": "input",
            "required": true
          },
          {
            "field": "content",
            "title": "Content",
            "type": "textarea",
            "span": 2
          },
          {
            "field": "status",
            "title": "Status",
            "type": "input"
          },
          {
            "field": "created_by",
            "title": "Created by",
            "type": "number"
          }
        ]
      }
    ],
    "modes": {
      "create": {
        "fields": [
          "tenant_id",
          "module_code",
          "category_id",
          "title",
          "content",
          "status",
          "created_by"
        ]
      },
      "edit": {
        "fields": [
          "tenant_id",
          "module_code",
          "category_id",
          "title",
          "content",
          "status",
          "created_by"
        ]
      },
      "view": {
        "fields": [
          "id",
          "tenant_id",
          "module_code",
          "category_id",
          "title",
          "content",
          "status",
          "created_by",
          "created_at",
          "updated_at"
        ]
      }
    }
  }
}
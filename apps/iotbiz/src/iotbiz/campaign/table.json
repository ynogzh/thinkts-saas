{
  "title": "营销活动",
  "model": "iotbiz_campaign",
  "list": {
    "pageSize": 20,
    "columns": [
      { "field": "id", "title": "ID", "width": 80 },
      { "field": "name", "title": "名称", "width": 160 },
      { "field": "campaign_type", "title": "类型", "width": 120, "render": "tag" },
      { "field": "scene_code", "title": "场景", "width": 120 },
      { "field": "status", "title": "状态", "width": 100, "render": "tag" }
    ]
  },
  "search": {
    "fields": [
      { "field": "name", "title": "名称", "type": "input" },
      { "field": "status", "title": "状态", "type": "select" }
    ]
  },
  "form": {
    "groups": [
      {
        "title": "基础信息",
        "columns": 2,
        "fields": [
          { "field": "tenant_id", "title": "租户", "type": "number", "required": true },
          { "field": "code", "title": "编码", "type": "input", "required": true },
          { "field": "name", "title": "名称", "type": "input", "required": true },
          { "field": "campaign_type", "title": "类型", "type": "select", "required": true, "options": [
            { "label": "优惠券", "value": "coupon" },
            { "label": "通行证", "value": "pass" },
            { "label": "设备活动", "value": "device" }
          ] },
          { "field": "scene_code", "title": "场景", "type": "input" },
          { "field": "coupon_template_id", "title": "券模板", "type": "select", "optionsSource": { "resourcePath": "promote/coupon/template", "labelFields": ["name", "code"], "valueField": "id" } },
          { "field": "start_at", "title": "开始时间", "type": "datetime" },
          { "field": "end_at", "title": "结束时间", "type": "datetime" },
          { "field": "status", "title": "状态", "type": "select", "options": [
            { "label": "草稿", "value": "draft" },
            { "label": "进行中", "value": "active" },
            { "label": "暂停", "value": "paused" },
            { "label": "归档", "value": "archived" }
          ] },
          { "field": "device_scope_json", "title": "设备范围", "type": "json", "span": 2 },
          { "field": "package_scope_json", "title": "套餐范围", "type": "json", "span": 2 },
          { "field": "rule_json", "title": "规则", "type": "json", "span": 2 }
        ]
      }
    ],
    "modes": {
      "create": { "fields": ["tenant_id", "code", "name", "campaign_type", "scene_code", "coupon_template_id", "start_at", "end_at", "status", "device_scope_json", "package_scope_json", "rule_json"] },
      "edit": { "fields": ["name", "campaign_type", "scene_code", "coupon_template_id", "start_at", "end_at", "status", "device_scope_json", "package_scope_json", "rule_json"] },
      "view": { "fields": ["tenant_id", "code", "name", "campaign_type", "scene_code", "coupon_template_id", "start_at", "end_at", "status", "published_at", "device_scope_json", "package_scope_json", "rule_json"] }
    }
  }
}

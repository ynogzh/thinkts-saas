{
  "title": "设备参数模板",
  "model": "iotbiz_param_template",
  "list": {
    "pageSize": 20,
    "columns": [
      { "field": "id", "title": "ID", "width": 80 },
      { "field": "name", "title": "名称", "width": 160 },
      { "field": "type_id", "title": "设备类型", "width": 100 },
      { "field": "start_mode", "title": "启动方式", "width": 100, "render": "tag" },
      { "field": "status", "title": "状态", "width": 100, "render": "tag" }
    ]
  },
  "search": { "fields": [ { "field": "name", "title": "名称", "type": "input" }, { "field": "status", "title": "状态", "type": "select" } ] },
  "form": {
    "groups": [
      { "title": "模板信息", "columns": 2, "fields": [
        { "field": "tenant_id", "title": "租户", "type": "number", "required": true },
        { "field": "code", "title": "编码", "type": "input", "required": true },
        { "field": "name", "title": "名称", "type": "input", "required": true },
        { "field": "type_id", "title": "设备类型", "type": "select", "optionsSource": { "resourcePath": "iotbiz/device/type", "labelFields": ["name", "code"], "valueField": "id" } },
        { "field": "start_mode", "title": "启动方式", "type": "select", "options": [ { "label": "模拟", "value": "mock" }, { "label": "MQTT", "value": "mqtt" }, { "label": "HTTP", "value": "http" } ] },
        { "field": "status", "title": "状态", "type": "select", "options": [ { "label": "启用", "value": "enabled" }, { "label": "停用", "value": "disabled" } ] },
        { "field": "pricing_json", "title": "价格参数", "type": "json", "span": 2 },
        { "field": "start_config_json", "title": "启动参数", "type": "json", "span": 2 },
        { "field": "metadata_json", "title": "扩展信息", "type": "json", "span": 2 }
      ] }
    ],
    "modes": {
      "create": { "fields": ["tenant_id", "code", "name", "type_id", "start_mode", "status", "pricing_json", "start_config_json", "metadata_json"] },
      "edit": { "fields": ["name", "type_id", "start_mode", "status", "pricing_json", "start_config_json", "metadata_json"] },
      "view": { "fields": ["tenant_id", "code", "name", "type_id", "start_mode", "status", "pricing_json", "start_config_json", "metadata_json"] }
    }
  }
}

      "edit": {
        "fields": [
          "tenant_id",
          "device_id",
          "session_id",
          "command_type",
          "status",
          "request_payload_json",
          "response_payload_json"
        ]
      },
      "view": {
        "fields": [
          "id",
          "tenant_id",
          "device_id",
          "session_id",
          "command_type",
          "status",
          "request_payload_json",
          "response_payload_json",
          "created_at",
          "updated_at"
        ]
      }
    }

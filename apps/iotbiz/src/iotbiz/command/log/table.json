            "type": "number",
            "required": true
          },
          {
            "field": "device_id",
            "title": "Device id",
            "type": "number",
            "required": true
          },
          {
            "field": "session_id",
            "title": "Session id",
            "type": "number"
          },
          {
            "field": "command_type",

      {
        "field": "device_id",
        "title": "Device id",
        "type": "numberRange"
      },
      {
        "field": "command_type",
        "title": "Command type",
        "type": "input"
      },
      {
        "field": "status",
        "title": "Status",
        "type": "input"
      }
